{
    "yaml.schemas": {
        "https://raw.githubusercontent.com/helm-unittest/helm-unittest/v1.1.1/schema/helm-testsuite.json": [
            "/unittests/**/*.yaml"
        ],
        "https://docs.renovatebot.com/renovate-schema.json":[
          "renovate.json",
          "renovate.json5"
        ]
    },
    "yaml.schemaStore.enable": true,
    "[bats]": {
        "editor.tabSize": 2
    },
    "[shellscript]": {
        "files.eol": "\n",
        "editor.tabSize": 2
    }
}
